{
  "name": "veyrapro",
  "private": true,
  "version": "0.1.0",
  "description": "AI-powered sports prediction platform — ingestion, ML + Claude analysis, accumulator generation and performance tracking.",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter @veyrapro/web dev",
    "dev:worker": "pnpm --filter @veyrapro/worker dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @veyrapro/database prisma:generate",
    "db:migrate": "pnpm --filter @veyrapro/database prisma:migrate",
    "db:studio": "pnpm --filter @veyrapro/database prisma:studio"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
