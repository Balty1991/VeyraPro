    "settle": "tsx src/settlement/run.ts"
  },
  "dependencies": {
    "@veyrapro/accumulator-engine": "workspace:*",
    "@veyrapro/ai-engine": "workspace:*",
    "@veyrapro/database": "workspace:*",
    "@veyrapro/domain": "workspace:*",
    "@veyrapro/sports-api-client": "workspace:*",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
