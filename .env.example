# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://veyrapro:veyrapro@localhost:5432/veyrapro"

# ---------------------------------------------------------------------------
# Sports data provider (the "Veyra" feed) — fixtures, H2H, form, coaches,
# odds + movement across ~14 bookmakers, native ML predictions, weather.
# ---------------------------------------------------------------------------
SPORTS_API_BASE_URL="https://api.your-sports-provider.example/v1"
SPORTS_API_KEY="replace-with-real-key"

# Comma-separated league IDs to ingest. Leave empty to pull every league the
# provider exposes.
LEAGUE_IDS=""

# ---------------------------------------------------------------------------
# Claude (Anthropic) — the analysis engine
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-..."
# claude-sonnet-5 (default, balanced) or claude-opus-4-8 (deeper reasoning, slower/costlier)
ANTHROPIC_MODEL="claude-sonnet-5"
# Language the AI writes reasoning/riskNotes in.
ANALYSIS_LANGUAGE="română"
# How many matches to analyze concurrently per pass.
AI_ANALYSIS_CONCURRENCY="5"

# ---------------------------------------------------------------------------
# Worker scheduling (5-field cron expressions)
# ---------------------------------------------------------------------------
INGEST_CRON="*/30 * * * *"
ANALYSIS_CRON="*/15 * * * *"
SETTLEMENT_CRON="0 * * * *"

# ---------------------------------------------------------------------------
# Web app
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="VeyraPro"
